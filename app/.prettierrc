{
  "singleQuote": true,
  "semi": true,
  "printWidth": 100,
  "tabWidth": 2,
  "trailingComma": "es5",
  "arrowParens": "avoid",
  "quoteProps": "consistent",
  "bracketSameLine": true,
  "plugins": ["prettier-plugin-organize-attributes"],
  "attributeGroups": ["^id$", "^class$", "^src$", "^width$", "^height$", "^alt$", "^loading$", "^role$", "$DEFAULT", "^data-"],
  "overrides": [
    {
      "files": ["*.html"],
      "options": {
        "printWidth": 9999
      }
    }
  ]
}
